<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Estúdio Confessionário — Design & Arquitetura para Marcas</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,300;1,400;1,500&family=Unbounded:wght@200;300;400;700;900&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;}
:root{
  --white:#ffffff;
  --gray-light:#F4F3F0;
  --gray-mid:#E8E6E1;
  --black:#111110;
  --text-muted:#6B6A66;
  --border:#DDDBD5;
  --ease:cubic-bezier(0.16,1,0.3,1);
}
html{scroll-behavior:smooth;}
body{
  font-family:'Inter',sans-serif;
  background:var(--white);
  color:var(--black);
  overflow-x:hidden;
  cursor:none;
}

/* CURSOR */
.cursor-dot{
  width:8px;height:8px;
  background:var(--black);border-radius:50%;
  position:fixed;pointer-events:none;z-index:9999;
  transform:translate(-50%,-50%);
  transition:background 0.2s;
}
.cursor-ring{
  width:36px;height:36px;
  border:0.5px solid rgba(17,17,16,0.4);
  border-radius:50%;
  position:fixed;pointer-events:none;z-index:9998;
  transform:translate(-50%,-50%);
  transition:width 0.3s var(--ease),height 0.3s var(--ease),border-color 0.3s;
}
.cursor-ring.hovered{width:56px;height:56px;border-color:rgba(17,17,16,0.2);}
.cursor-ring.hero-zone{border-color:rgba(255,255,255,0.4);}
.cursor-dot.hero-zone{background:#fff;}

/* NAV */
nav{
  display:flex;justify-content:space-between;align-items:center;
  padding:24px 48px;
  background:transparent;
  position:fixed;top:0;left:0;right:0;z-index:100;
  transition:background 0.4s ease,backdrop-filter 0.4s ease,padding 0.4s ease;
}
nav.scrolled{
  padding-top:16px;padding-bottom:16px;
  background:rgba(255,255,255,0.88);
  backdrop-filter:blur(16px) saturate(1.2);
  -webkit-backdrop-filter:blur(16px) saturate(1.2);
  border-bottom:0.5px solid var(--border);
}
.nav-logo{
  font-family:'Inter',sans-serif;
  font-size:11px;font-weight:400;letter-spacing:0.12em;text-transform:uppercase;
  color:#fff;
  transition:color 0.3s;
}
nav.scrolled .nav-logo{color:var(--black);}
.nav-links{display:flex;gap:32px;list-style:none;}
.nav-links a{
  font-size:11px;letter-spacing:0.08em;text-transform:uppercase;
  color:rgba(255,255,255,0.6);text-decoration:none;transition:color 0.2s;
}
nav.scrolled .nav-links a{color:var(--text-muted);}
.nav-links a:hover{color:#fff;}
nav.scrolled .nav-links a:hover{color:var(--black);}
.nav-cta{
  font-size:11px;letter-spacing:0.08em;text-transform:uppercase;
  border:0.5px solid rgba(255,255,255,0.4);padding:8px 20px;
  border-radius:100px;color:#fff;text-decoration:none;
  transition:background 0.2s,color 0.2s,border-color 0.3s;
}
nav.scrolled .nav-cta{border-color:var(--black);color:var(--black);}
.nav-cta:hover{background:rgba(255,255,255,0.12);}
nav.scrolled .nav-cta:hover{background:var(--black);color:#fff;}

/* HERO — texto no canto inferior esquerdo como na referência */
.hero{
  position:relative;
  height:100svh;
  overflow:hidden;
  color:#fff;
  background:#0a0a0a;
  display:flex;
  align-items:flex-end;
  padding:0 48px 48px;
  margin:0;border:none;
}
.hero-bg{
  position:absolute;inset:0;z-index:0;
  background:#0a0a0a;
  overflow:hidden;
}
.hero-bg img{
  position:absolute;
  width:100%;height:130%;
  top:-15%;
  object-fit:cover;object-position:center right;
  opacity:0.9;
  will-change:transform;
}
.hero-overlay{
  position:absolute;inset:0;z-index:1;
  background:linear-gradient(
    175deg,
    rgba(0,0,0,0.05) 0%,
    rgba(0,0,0,0.3) 40%,
    rgba(0,0,0,0.75) 100%
  );
}
.hero-content{
  position:relative;z-index:2;
  max-width:620px;
}
.hero-kicker{
  display:block;
  font-size:11px;letter-spacing:0.14em;text-transform:uppercase;
  color:rgba(255,255,255,0.4);
  margin-bottom:20px;
  display:flex;align-items:center;gap:10px;
}
.hero-kicker::before{
  content:'';display:inline-block;width:20px;height:0.5px;background:rgba(255,255,255,0.4);
}
.hero-title{
  font-family:'Inter',sans-serif;
  font-size:100px;
  font-weight:700;
  line-height:1.0;
  letter-spacing:-0.04em;
  margin-bottom:28px;
  color:#fff;
}
.hero-title .thin{font-weight:200;color:rgba(255,255,255,0.45);}

/* Line reveal */
.line-wrap{overflow:hidden;display:block;}
.line{
  display:block;
  transform:translateY(105%);opacity:0;
  transition:transform 0.9s var(--ease),opacity 0.4s ease;
}
.line.in{transform:translateY(0);opacity:1;}
.line-wrap:nth-child(1) .line{transition-delay:0.05s;}
.line-wrap:nth-child(2) .line{transition-delay:0.15s;}
.line-wrap:nth-child(3) .line{transition-delay:0.25s;}

.hero-bottom{
  display:flex;align-items:center;gap:32px;
  opacity:0;transform:translateY(12px);
  transition:opacity 0.8s var(--ease) 0.55s,transform 0.8s var(--ease) 0.55s;
}
.hero-bottom.in{opacity:1;transform:none;}
.hero-sub{
  font-size:18px;color:rgba(255,255,255,0.5);line-height:1.65;max-width:320px;
}
.btn-pill{
  flex-shrink:0;
  font-size:11px;letter-spacing:0.08em;text-transform:uppercase;
  border:0.5px solid rgba(255,255,255,0.3);color:#fff;background:transparent;
  padding:12px 24px;border-radius:100px;cursor:none;
  transition:background 0.25s ease,border-color 0.25s ease;
  white-space:nowrap;
}
.btn-pill:hover{background:rgba(255,255,255,0.1);border-color:rgba(255,255,255,0.6);}

/* Ícones sociais lado direito — como na referência */
.hero-socials{
  position:absolute;right:32px;top:50%;transform:translateY(-50%);
  z-index:3;display:flex;flex-direction:column;gap:20px;
}
.hero-socials a{
  font-size:10px;letter-spacing:0.1em;text-transform:uppercase;
  color:rgba(255,255,255,0.35);text-decoration:none;
  writing-mode:vertical-rl;
  transition:color 0.2s;
}
.hero-socials a:hover{color:#fff;}


/* SERVICES */
.services{
  background:var(--gray-light);padding:100px 48px;
}
.sec-head{
  display:flex;justify-content:space-between;align-items:center;margin-bottom:40px;
}
.sec-label{font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--text-muted);}
.sec-count{font-size:11px;color:var(--text-muted);}
.svc-row{
  display:flex;justify-content:space-between;align-items:center;
  padding:20px 0;border-top:0.5px solid var(--border);cursor:none;
  transition:padding-left 0.35s var(--ease);
}
.svc-row:hover{padding-left:14px;}
.svc-row:last-child{border-bottom:0.5px solid var(--border);}
.svc-num{font-family:'Inter',sans-serif;font-size:11px;font-weight:200;color:var(--text-muted);width:36px;flex-shrink:0;}
.svc-name{font-family:'Inter',sans-serif;font-size:18px;font-weight:400;flex:1;padding-left:20px;transition:opacity 0.2s;}
.svc-row:hover .svc-name{opacity:0.6;}
.svc-desc{font-size:12px;color:var(--text-muted);max-width:220px;text-align:right;line-height:1.5;}
.svc-arrow{font-size:18px;color:var(--text-muted);margin-left:20px;flex-shrink:0;}

/* PORTFOLIO SLIDER */
.portfolio{
  background:#0a0a0a;
  padding:80px 0 100px;
  position:relative;
  overflow:hidden;
  margin:0;border:none;
}
.hero-fade{
  position:absolute;
  bottom:0;left:0;right:0;
  height:200px;
  background:linear-gradient(to bottom,transparent 0%,#0a0a0a 100%);
  z-index:3;
  pointer-events:none;
}
.portfolio-head{
  display:flex;justify-content:space-between;align-items:center;
  padding:0 48px;margin-bottom:40px;
  position:relative;z-index:2;
}
.sw-slider-outer{position:relative;z-index:2;}
.sw-footer{
  position:relative;z-index:2;
}
.portfolio-ttl{
  font-family:'Inter',sans-serif;font-size:clamp(22px,3vw,36px);
  font-weight:300;color:#fff;letter-spacing:-0.02em;
}
.portfolio-ttl em{font-weight:200;color:rgba(255,255,255,0.3);font-style:normal;}
.portfolio-all{
  font-size:11px;letter-spacing:0.08em;text-transform:uppercase;
  color:rgba(255,255,255,0.4);text-decoration:none;
  transition:color 0.2s;
}
.portfolio-all:hover{color:#fff;}

/* Slider */
.sw-slider-outer{position:relative;}
.sw-track-container{overflow:hidden;padding:0 48px;}
.sw-track{
  display:flex;gap:12px;
  transition:transform 0.72s cubic-bezier(0.16,1,0.3,1);
  will-change:transform;
}
.sw-card{
  flex:0 0 calc(50% - 6px);min-width:0;
  position:relative;aspect-ratio:16/11;
  border-radius:4px;overflow:hidden;cursor:none;
  background:#1a1a1a;
}
.sw-card__img{
  position:absolute;inset:0;width:100%;height:100%;object-fit:cover;
  transition:transform 0.9s cubic-bezier(0.25,0.46,0.45,0.94);
}
.sw-card:hover .sw-card__img{transform:scale(1.04);}
.sw-card__overlay{
  position:absolute;inset:0;
  background:linear-gradient(to bottom,rgba(0,0,0,0) 50%,rgba(0,0,0,0.72) 100%);
  pointer-events:none;
}
.sw-card__tags{
  position:absolute;top:20px;left:20px;
  font-size:10px;letter-spacing:0.13em;text-transform:uppercase;
  color:rgba(255,255,255,0.6);z-index:2;
}
.sw-card__corner{
  position:absolute;top:0;right:0;width:0;height:0;
  border-style:solid;border-width:0 40px 40px 0;
  border-color:transparent rgba(255,255,255,0.9) transparent transparent;
  z-index:3;
}
.sw-card__placeholder{
  position:absolute;inset:0;display:flex;align-items:center;
  justify-content:center;flex-direction:column;gap:8px;
}
.sw-card__placeholder-label{
  font-size:11px;letter-spacing:0.12em;text-transform:uppercase;
  color:rgba(255,255,255,0.15);
}
.sw-card__info{
  position:absolute;bottom:0;left:0;right:0;
  padding:20px 22px 24px;z-index:2;
}
.sw-card__name{
  font-family:'Inter',sans-serif;
  font-size:clamp(16px,1.8vw,22px);font-weight:400;
  color:#fff;margin-bottom:5px;
}
.sw-card__desc{
  font-size:12px;color:rgba(255,255,255,0.55);line-height:1.5;max-width:85%;
}
.sw-card--1{background:#1a1a1a;}
.sw-card--2{background:#0e2820;}
.sw-card--3{background:#1a1510;}
.sw-card--4{background:#12121e;}
.sw-card--5{background:#1e1010;}
.sw-card--6{background:#101e10;}

/* Controles */
.sw-controls{
  position:absolute;top:50%;left:50%;
  transform:translate(-50%,-50%);
  display:flex;align-items:center;gap:2px;z-index:10;
}
.sw-btn{
  width:52px;height:52px;border-radius:50%;
  background:rgba(10,10,10,0.82);
  backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);
  border:0.5px solid rgba(255,255,255,0.18);
  color:#fff;font-size:16px;cursor:none;
  display:flex;align-items:center;justify-content:center;
  transition:background 0.2s ease,transform 0.15s ease;
}
.sw-btn:hover{background:rgba(40,40,40,0.92);}
.sw-btn:active{transform:scale(0.94);}
.sw-btn svg{width:18px;height:18px;}

/* Dots */
.sw-dots{
  display:flex;align-items:center;justify-content:center;
  gap:6px;margin-top:28px;
  position:relative;z-index:2;
}
.sw-dot{
  width:6px;height:6px;border-radius:50%;
  background:rgba(255,255,255,0.22);cursor:none;
  transition:background 0.3s ease,transform 0.3s ease;border:none;
}
.sw-dot.active{background:rgba(255,255,255,0.85);transform:scale(1.2);}

.sw-footer{
  display:flex;align-items:center;padding:32px 48px 0;gap:12px;
}
.sw-footer-line{width:28px;height:1px;background:rgba(255,255,255,0.25);}
.sw-footer-text{font-size:13px;letter-spacing:0.05em;color:rgba(255,255,255,0.35);font-weight:300;}

/* O QUE FAZEMOS */
.oqf{
  background:#F4F3F0;
  padding:120px 48px;
  display:grid;
  grid-template-columns:1fr 3fr;
  gap:48px;
  align-items:start;
}
.oqf-label{
  font-size:11px;
  letter-spacing:0.13em;
  text-transform:uppercase;
  color:#6B6A66;
  padding-top:6px;
}
.oqf-content{}
.oqf-body{
  font-family:'Unbounded',sans-serif;
  font-size:clamp(24px,3.5vw,48px);
  font-weight:300;
  color:#111110;
  line-height:1.35;
  margin-bottom:48px;
}
.scroll-word{
  display:inline;
  opacity:0.15;
}
.oqf-link{
  display:inline-flex;
  align-items:center;
  gap:8px;
  font-size:12px;
  letter-spacing:0.08em;
  text-transform:uppercase;
  color:var(--text-muted);
  text-decoration:none;
  transition:color 0.2s;
}
.oqf-link:hover{color:var(--black);}

/* STATS */
.stats{
  background:var(--white);display:grid;grid-template-columns:repeat(3,1fr);
  border-bottom:0.5px solid var(--border);
}
.stat{padding:100px 48px;}
.stat+.stat{border-left:0.5px solid var(--border);}
.stat-num{
  font-family:'Inter',sans-serif;
  font-size:clamp(40px,5vw,64px);font-weight:700;line-height:1;margin-bottom:10px;
}
.stat-desc{font-size:12px;color:var(--text-muted);line-height:1.55;}

/* FOOTER */
footer{background:var(--black);color:var(--white);}
.ft-top{
  display:flex;justify-content:space-between;align-items:flex-end;
  padding:72px 48px 48px;border-bottom:0.5px solid rgba(255,255,255,0.08);
}
.ft-logo{
  font-family:'Inter',sans-serif;
  font-size:clamp(28px,5.5vw,80px);font-weight:900;
  letter-spacing:-0.03em;line-height:0.95;
}
.ft-logo .thin{font-weight:200;color:rgba(255,255,255,0.25);}
.ft-cta{text-align:right;}
.ft-cta-label{font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.3);margin-bottom:14px;}
.ft-btn{
  display:inline-block;font-size:12px;letter-spacing:0.06em;text-transform:uppercase;
  border:0.5px solid rgba(255,255,255,0.25);padding:12px 28px;
  border-radius:100px;color:var(--white);text-decoration:none;
  transition:border-color 0.2s,background 0.2s;
}
.ft-btn:hover{border-color:var(--white);background:rgba(255,255,255,0.07);}
.ft-cols{
  display:grid;grid-template-columns:repeat(3,1fr);
  border-bottom:0.5px solid rgba(255,255,255,0.08);
}
.ft-col{padding:36px 48px;border-right:0.5px solid rgba(255,255,255,0.08);}
.ft-col:last-child{border-right:none;}
.ft-col-label{font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:rgba(255,255,255,0.25);margin-bottom:18px;}
.ft-col ul{list-style:none;}
.ft-col li{margin-bottom:8px;}
.ft-col a{font-size:13px;color:rgba(255,255,255,0.5);text-decoration:none;transition:color 0.2s;}
.ft-col a:hover{color:var(--white);}
.ft-base{display:flex;justify-content:space-between;align-items:center;padding:18px 48px;}
.ft-copy{font-size:11px;color:rgba(255,255,255,0.25);}
.ft-loc{font-size:11px;color:rgba(255,255,255,0.25);}

/* REVEAL */
.reveal{opacity:0;transform:translateY(28px);transition:opacity 0.85s var(--ease),transform 0.85s var(--ease);}
.reveal.in{opacity:1;transform:none;}
.d1{transition-delay:0.1s;}.d2{transition-delay:0.2s;}.d3{transition-delay:0.3s;}
</style>
</head>
<body>

<div class="cursor-dot" id="cursorDot"></div>
<div class="cursor-ring" id="cursorRing"></div>

<nav id="mainNav">
  <span class="nav-logo">Confessionário</span>
  <ul class="nav-links">
    <li><a href="#">O Estúdio</a></li>
    <li><a href="#">Projetos</a></li>
    <li><a href="#">Serviços</a></li>
  </ul>
  <a class="nav-cta" href="#">Contato</a>
</nav>

<!-- HERO — texto embaixo à esquerda, imagem à direita -->
<section class="hero" id="hero">
  <div class="hero-bg">
    <img src="/hero-bg.jpg" alt="" aria-hidden="true">
  </div>
  <div class="hero-overlay"></div>

  <!-- Sociais lado direito -->
  <div class="hero-socials">
    <a href="#">Ig</a>
    <a href="#">Be</a>
    <a href="#">Li</a>
  </div>

  <div class="hero-content">
    <span class="hero-kicker">Estúdio Criativo — Campinas, Brasil</span>
    <h1 class="hero-title" id="heroTitle">
      <span class="line-wrap"><span class="line">Design &amp;</span></span>
      <span class="line-wrap"><span class="line"><span class="thin">Arquitetura</span></span></span>
      <span class="line-wrap"><span class="line">para Marcas.</span></span>
    </h1>
    <div class="hero-bottom" id="heroBottom">
      <p class="hero-sub">Projetamos marcas e espaços que geram valor percebido e performance real para os negócios.</p>
      <button class="btn-pill">Ver projetos →</button>
    </div>
  </div>
  <div class="hero-fade"></div>
</section>

<!-- PORTFOLIO SLIDER -->
<section class="portfolio">
  <div class="portfolio-head reveal">
    <h2 class="portfolio-ttl">Projetos <em>selecionados</em></h2>
    <a class="portfolio-all" href="#">Ver portfólio completo →</a>
  </div>

  <div class="sw-slider-outer">
    <div class="sw-track-container">
      <div class="sw-track" id="swTrack">

        <article class="sw-card sw-card--1" data-href="/projetos/boro">
          <div class="sw-card__placeholder"><svg width="36" height="36" viewBox="0 0 36 36" fill="none"><rect x="4" y="8" width="28" height="20" rx="2" stroke="rgba(255,255,255,0.1)" stroke-width="1"/><circle cx="12" cy="15" r="3" stroke="rgba(255,255,255,0.1)" stroke-width="1"/><path d="M4 24l7-6 5 4 5-5 11 7" stroke="rgba(255,255,255,0.1)" stroke-width="1" fill="none"/></svg><span class="sw-card__placeholder-label">Foto do projeto</span></div>
          <div class="sw-card__overlay"></div>
          <div class="sw-card__tags">Branding, Arquitetura Comercial</div>
          <div class="sw-card__corner"></div>
          <svg style="position:absolute;top:7px;right:7px;z-index:4;pointer-events:none;" width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 10L10 2M10 2H4M10 2V8" stroke="#0a0a0a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <div class="sw-card__info">
            <div class="sw-card__name">BORÓ Botequim</div>
            <div class="sw-card__desc">Identidade e arquitetura para botequim contemporâneo em Campinas.</div>
          </div>
        </article>

        <article class="sw-card sw-card--2" data-href="/projetos/uaubox">
          <div class="sw-card__placeholder"><svg width="36" height="36" viewBox="0 0 36 36" fill="none"><rect x="4" y="8" width="28" height="20" rx="2" stroke="rgba(255,255,255,0.1)" stroke-width="1"/><circle cx="12" cy="15" r="3" stroke="rgba(255,255,255,0.1)" stroke-width="1"/><path d="M4 24l7-6 5 4 5-5 11 7" stroke="rgba(255,255,255,0.1)" stroke-width="1" fill="none"/></svg><span class="sw-card__placeholder-label">Foto do projeto</span></div>
          <div class="sw-card__overlay"></div>
          <div class="sw-card__tags">Rebrand, Identidade Visual, Embalagem</div>
          <div class="sw-card__corner"></div>
          <svg style="position:absolute;top:7px;right:7px;z-index:4;pointer-events:none;" width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 10L10 2M10 2H4M10 2V8" stroke="#0a0a0a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <div class="sw-card__info">
            <div class="sw-card__name">UAUBox</div>
            <div class="sw-card__desc">Rebrand completo para a maior subscription box do Brasil.</div>
          </div>
