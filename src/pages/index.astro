<script>
// CURSOR
const dot=document.getElementById('cursorDot'),ring=document.getElementById('cursorRing');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;});
(function tick(){
  dot.style.left=mx+'px';dot.style.top=my+'px';
  rx+=(mx-rx)*0.1;ry+=(my-ry)*0.1;
  ring.style.left=rx+'px';ring.style.top=ry+'px';
  requestAnimationFrame(tick);
})();
document.querySelectorAll('a,button,.svc-row,.sw-card').forEach(el=>{
  el.addEventListener('mouseenter',()=>ring.classList.add('hovered'));
  el.addEventListener('mouseleave',()=>ring.classList.remove('hovered'));
});
const heroEl=document.getElementById('hero');
heroEl.addEventListener('mouseenter',()=>{dot.classList.add('hero-zone');ring.classList.add('hero-zone');});
heroEl.addEventListener('mouseleave',()=>{dot.classList.remove('hero-zone');ring.classList.remove('hero-zone');});

// NAV SCROLL + PARALLAX
const nav=document.getElementById('mainNav');
const heroBgImg=document.querySelector('.hero-bg img');
window.addEventListener('scroll',()=>{
  const sy=window.scrollY;
  nav.classList.toggle('scrolled',sy>60);
  if(heroBgImg) heroBgImg.style.transform=`translateY(${sy*0.35}px)`;
},{passive:true});

// REVEAL
const revObs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('in');});
},{threshold:0.1,rootMargin:'0px 0px -32px 0px'});
document.querySelectorAll('.reveal').forEach(el=>revObs.observe(el));

// HERO LINES
window.addEventListener('load',()=>{
  setTimeout(()=>{
    document.querySelectorAll('.hero-title .line').forEach(l=>l.classList.add('in'));
    setTimeout(()=>document.getElementById('heroBottom').classList.add('in'),400);
  },150);

  // O QUE FAZEMOS — scroll-driven word reveal
  (function(){
    const wordEls=Array.from(document.querySelectorAll('.scroll-word'));
    if(!wordEls.length)return;
    const RANGE=120;
    let ticking=false;
    function updateWords(){
      const center=window.innerHeight*0.5;
      wordEls.forEach(el=>{
        const rect=el.getBoundingClientRect();
        const mid=rect.top+rect.height*0.5;
        const progress=Math.max(0,Math.min(1,(center+RANGE*0.5-mid)/RANGE));
        el.style.opacity=0.15+progress*0.85;
      });
      ticking=false;
    }
    function onScroll(){
      if(!ticking){requestAnimationFrame(updateWords);ticking=true;}
    }
    window.addEventListener('scroll',onScroll,{passive:true});
    window.addEventListener('resize',onScroll,{passive:true});
    updateWords();
  })();

  // COUNTUP
  function countUp(el,target,suffix,duration=1600){
    const start=performance.now();
    const update=now=>{
      const p=Math.min((now-start)/duration,1);
      const eased=1-Math.pow(1-p,3);
      el.textContent=Math.round(eased*target)+(p>=1?suffix:'');
      if(p<1)requestAnimationFrame(update);
    };
    requestAnimationFrame(update);
  }
  const cntObs=new IntersectionObserver(entries=>{
    entries.forEach(e=>{
      if(e.isIntersecting){
        const el=e.target;
        countUp(el,+el.dataset.count,el.dataset.suffix||'');
        cntObs.unobserve(el);
      }
    });
  },{threshold:0.5});
  document.querySelectorAll('[data-count]').forEach(el=>cntObs.observe(el));
});

// PORTFOLIO SLIDER
(function(){
  const track=document.getElementById('swTrack');
  const dotsEl=document.getElementById('swDots');
  const btnPrev=document.getElementById('swPrev');
  const btnNext=document.getElementById('swNext');
  const cards=Array.from(track.querySelectorAll('.sw-card'));
  const PAIRS=Math.ceil(cards.length/2);
  let current=0;

  for(let i=0;i<PAIRS;i++){
    const d=document.createElement('button');
    d.className='sw-dot'+(i===0?' active':'');
    d.setAttribute('aria-label','Par '+(i+1));
    d.addEventListener('click',()=>goTo(i));
    dotsEl.appendChild(d);
  }

  function getOffset(index){
    const card=cards[0];
    const cardW=card.getBoundingClientRect().width;
    return index*2*(cardW+12);
  }

  function goTo(index){
    if(index<0)index=PAIRS-1;
    if(index>=PAIRS)index=0;
    current=index;
    track.style.transform=`translateX(-${getOffset(index)}px)`;
    dotsEl.querySelectorAll('.sw-dot').forEach((d,i)=>d.classList.toggle('active',i===index));
  }

  btnPrev.addEventListener('click',()=>goTo(current-1));
  btnNext.addEventListener('click',()=>goTo(current+1));
  cards.forEach(card=>{
    card.addEventListener('click',function(){
      if(this.dataset.href)window.location.href=this.dataset.href;
    });
  });
  document.addEventListener('keydown',e=>{
    if(e.key==='ArrowLeft')goTo(current-1);
    if(e.key==='ArrowRight')goTo(current+1);
  });
  let startX=0;
  track.addEventListener('touchstart',e=>{startX=e.touches[0].clientX;},{passive:true});
  track.addEventListener('touchend',e=>{
    const diff=startX-e.changedTouches[0].clientX;
    if(Math.abs(diff)>40)goTo(diff>0?current+1:current-1);
  });
  window.addEventListener('resize',()=>goTo(current));
  goTo(0);
})();
</script>
